lookup spaceBeforeAlefHamza {
  pos [\uni0648 \uniFEEE \uni0631 \uniFEAE \uni0632 \uniFEB0] \uni0625 160;
  pos \uni0631.alt \uni0625 320;
} spaceBeforeAlefHamza;

# Initial kaaf (uniFEDB) collision spacing.
# Non-joining finals immediately precede uniFEDB (initial kaaf) with no connectors.
# A mark on the non-joiner OR on the letter following kaaf can collide with kaaf's arm.
# Pattern A (mark between non-join and kaaf in buffer):
#   chained-context: @nonJoinFinals @aboveMarks uniFEDB' value
# Pattern B (mark on the letter logically after kaaf, e.g. fatha on ذ in ذَكرناهم):
#   pair kern the non-joiner directly before kaaf: @nonJoinFinals uniFEDB value
#   (fires unconditionally when non-joiner precedes kaaf; a small gap is acceptable even
#    without marks, since this glyph pair always has a visual break anyway)
lookup spaceBeforeInitKaaf {
  pos @nonJoinFinals @aboveMarks uniFEDB' 500;
  pos @nonJoinFinals uniFEDB' 500;
} spaceBeforeInitKaaf;

feature kern {
  lookup spaceBeforeAlefHamza;
  lookup spaceBeforeInitKaaf;

 script DFLT;
     language dflt ;
      lookup kernHorizontalKerninginArabiclookup5;
      lookup kernHorizontalKerninglookup5;

 script arab;
     language dflt ;
      lookup kernHorizontalKerninginArabiclookup5;
     language ARA  exclude_dflt;
      lookup kernHorizontalKerninginArabiclookup5;
     language FAR  exclude_dflt;
      lookup kernHorizontalKerninginArabiclookup5;
     language PAS  exclude_dflt;
      lookup kernHorizontalKerninginArabiclookup5;
     language URD  exclude_dflt;
      lookup kernHorizontalKerninginArabiclookup5;

 script latn;
     language dflt ;
      lookup kernHorizontalKerninglookup5;
} kern;


